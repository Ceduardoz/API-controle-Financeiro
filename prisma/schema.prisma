generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum VaultStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum InvestmentType {
  CDB
  CDI
  LCI
  LCA
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())

  accounts       Account[]
  categories     Category[]
  transactions   Transaction[]
  recurringTransactions RecurringTransaction[]
  investiments   Investment[]

  vaults         Vault[] 
}

model Account {
  id             Int           @id @default(autoincrement())
  name           String
  type           AccountType
  Balance        Decimal       @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())

  userId         Int
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  outgoingTransactions Transaction[] @relation("FromAccount")
  incomingTransactions Transaction[] @relation("ToAccount")

  recurringTransactions RecurringTransaction[]
}

model Category {
  id                    Int       @id @default(autoincrement())
  name                  String
  color                 String    @default("#946afc")
  createdAt             DateTime  @default(now())
  categoryType          CategoryType?

  userId                Int?
  user                  User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, userId])

  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
}

model Transaction {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  date        DateTime
  createdAt   DateTime        @default(now())

  userId      Int
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId   Int?
  account     Account?        @relation("FromAccount", fields: [accountId], references: [id])

  toAccountId Int?
  toAccount   Account?        @relation("ToAccount", fields: [toAccountId], references: [id])

  fromVaultId Int?
  fromVault   Vault?          @relation("FromVault", fields: [fromVaultId], references: [id])

  toVaultId   Int?
  toVault     Vault?          @relation("ToVault", fields: [toVaultId], references: [id])

  categoryId  Int?
  category    Category?       @relation(fields: [categoryId], references: [id])

  recurringTransactionID Int?
  recurringTransaction RecurringTransaction? @relation(fields: [recurringTransactionID], references: [id]) 
}

model Vault {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  color       String          @default("#946afc")


  balance     Decimal         @db.Decimal(12,2) @default(0)
  targetAmount Decimal?       @db.Decimal(12,2)

  targetDate  DateTime?
  status      VaultStatus      @default(ACTIVE)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  userId      Int
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  incomingTransactions Transaction[] @relation("ToVault")
  outgoingTransactions Transaction[] @relation("FromVault")

  @@index([userId])
}

model RecurringTransaction {
  id           Int                 @id @default(autoincrement())
  title        String
  description  String?
  amount       Decimal             @db.Decimal(12, 2)
  type         TransactionType
  frequency    RecurrenceFrequency
  dayOfMonth   Int?
  dayOfWeek    Int?
  monthOfYear  Int?
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean             @default(true)
  lastRunAt    DateTime?
  createdAt    DateTime            @default(now())

  userId       Int
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId    Int
  account      Account             @relation(fields: [accountId], references: [id])

  categoryId   Int?
  category     Category?           @relation(fields: [categoryId], references: [id])

  transactions Transaction[]
}

model Investment {
  id              Int            @id @default(autoincrement())
  name            String
  type            InvestmentType
  institution     String?
  investedAmount  Decimal        @db.Decimal(12,2)
  annualRate      Decimal        @db.Decimal(5,2)
  startDate       DateTime
  createdAt       DateTime       @default(now())

  userId          Int
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}